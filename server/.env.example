PORT=3000

# ChromaDB
DB_HOST=localhost
DB_PORT=8000

# External APIs
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# CORS (set to your frontend domain in production)
CORS_ORIGIN=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# PostgreSQL
DATABASE_URL="postgresql://chatbot:password@localhost:5432/chatbot"
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=
POSTGRES_DB=chatbot

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@yourdomain.com
FRONTEND_URL=http://localhost:3001